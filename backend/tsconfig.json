{
  "compilerOptions": {
    // Cấu trúc thư mục Output
    "rootDir": "./src",
    "outDir": "./dist",

    // Cấu hình môi trường chạy hiện đại (Khớp với Node.js v24 trên Render)
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node"], // Khai báo các kiểu dữ liệu của môi trường Node.js

    // Các tệp tin bổ trợ cho Debug và biên dịch thư viện
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Kiểm tra kiểu dữ liệu nghiêm ngặt nâng cao (Senior Best Practices)
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Các cấu hình đề xuất đảm bảo an toàn mã nguồn
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true
    
    // ĐÃ LOẠI BỎ: "ignoreDeprecations": "6.0" để triệt tiêu hoàn toàn lỗi vạch đỏ hệ thống
  },
  "include": ["src/**/*"]
}